    titleBarBottom.Position = UDim2.new(0, 0, 1, -1)
    titleBarBottom.BackgroundColor3 = Theme.sidebarBorder
    titleBarBottom.BorderSizePixel = 0
    titleBarBottom.Parent = titleBar

    -- Logo dot
