-- ================================================
-- THEME  (dark mode  –  oklch -> RGB)
-- ================================================
local Theme = {
    background         = Color3.fromRGB(22,  22,  22),
    foreground         = Color3.fromRGB(251, 251, 251),
    card               = Color3.fromRGB(22,  22,  22),
    cardForeground     = Color3.fromRGB(251, 251, 251),
    primary            = Color3.fromRGB(251, 251, 251),
    primaryForeground  = Color3.fromRGB(40,  40,  40),
    secondary          = Color3.fromRGB(50,  50,  50),
    secondaryForeground= Color3.fromRGB(251, 251, 251),
    muted              = Color3.fromRGB(50,  50,  50),
    mutedForeground    = Color3.fromRGB(155, 155, 155),
    accent             = Color3.fromRGB(50,  50,  50),
    accentForeground   = Color3.fromRGB(251, 251, 251),
    border             = Color3.fromRGB(50,  50,  50),
    input              = Color3.fromRGB(50,  50,  50),
    destructive        = Color3.fromRGB(100, 40,  35),
    destructiveFg      = Color3.fromRGB(220, 80,  60),
    sidebar            = Color3.fromRGB(38,  38,  38),
    sidebarForeground  = Color3.fromRGB(251, 251, 251),
    sidebarBorder      = Color3.fromRGB(50,  50,  50),
    ring               = Color3.fromRGB(100, 100, 100),

    -- radius (px approx)
    radiusSm = 4,
    radiusMd = 6,
    radiusLg = 8,
    radiusXl = 12,
    radiusFull = 9999,

    font = Enum.Font.GothamMedium,
    fontMono = Enum.Font.Code,
}

-- ================================================
-- UTILITY
-- ================================================
local function makeCorner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or Theme.radiusMd)
    c.Parent = parent
    return c
end

local function makeStroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.border
    s.Thickness = thickness or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
    return s
end

local function makePadding(parent, top, right, bottom, left)
    local p = Instance.new("UIPadding")
    p.PaddingTop    = UDim.new(0, top    or 6)
    p.PaddingRight  = UDim.new(0, right  or 12)
    p.PaddingBottom = UDim.new(0, bottom or 6)
    p.PaddingLeft   = UDim.new(0, left   or 12)
    p.Parent = parent
    return p
end

local function tween(obj, info, props)
    local ts = game:GetService("TweenService")
    ts:Create(obj, info, props):Play()
end

local FAST = TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local MED  = TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

