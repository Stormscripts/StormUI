        sub.TextColor3 = Theme.mutedForeground
        sub.TextSize = 11
        sub.Font = Theme.font
        sub.TextXAlignment = Enum.TextXAlignment.Left
        sub.Parent = titleBar
    end

    -- Close button
    local closeBtn = Instance.new("TextButton")
    closeBtn.Name = "CloseBtn"
    closeBtn.Size = UDim2.fromOffset(28, 28)
    closeBtn.Position = UDim2.new(1, -36, 0.5, -14)
    closeBtn.BackgroundColor3 = Theme.secondary
    closeBtn.BorderSizePixel = 0
    closeBtn.Text = "✕"
    closeBtn.TextColor3 = Theme.mutedForeground
    closeBtn.TextSize = 11
    closeBtn.Font = Theme.font
    closeBtn.Parent = titleBar
    makeCorner(closeBtn, Theme.radiusMd)

    closeBtn.MouseEnter:Connect(function()
        tween(closeBtn, FAST, { BackgroundColor3 = Theme.destructive, TextColor3 = Color3.fromRGB(255,255,255) })
    end)
    closeBtn.MouseLeave:Connect(function()
        tween(closeBtn, FAST, { BackgroundColor3 = Theme.secondary, TextColor3 = Theme.mutedForeground })
    end)
    closeBtn.MouseButton1Click:Connect(function()
        gui:Destroy()
    end)

    -- Minimise button
    local minBtn = Instance.new("TextButton")
    minBtn.Name = "MinBtn"
    minBtn.Size = UDim2.fromOffset(28, 28)
    minBtn.Position = UDim2.new(1, -68, 0.5, -14)
    minBtn.BackgroundColor3 = Theme.secondary
    minBtn.BorderSizePixel = 0
    minBtn.Text = "–"
    minBtn.TextColor3 = Theme.mutedForeground
    minBtn.TextSize = 14
    minBtn.Font = Theme.font
    minBtn.Parent = titleBar
    makeCorner(minBtn, Theme.radiusMd)

    local minimized = false
    local originalSize = main.Size

    minBtn.MouseEnter:Connect(function()
        tween(minBtn, FAST, { BackgroundColor3 = Theme.accent, TextColor3 = Theme.foreground })
    end)
    minBtn.MouseLeave:Connect(function()
        tween(minBtn, FAST, { BackgroundColor3 = Theme.secondary, TextColor3 = Theme.mutedForeground })
    end)
    minBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        if minimized then
            tween(main, MED, { Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, 44) })
        else
            tween(main, MED, { Size = originalSize })
        end
    end)

    -- Content area
    local content = Instance.new("Frame")
    content.Name = "Content"
    content.Size = UDim2.new(1, 0, 1, -44)
    content.Position = UDim2.fromOffset(0, 44)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.Parent = main
    self._content = content

